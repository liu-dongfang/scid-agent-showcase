SCID_DEBUG=true
SCID_LOG_LEVEL=INFO
SCID_WORKFLOW_PATH=configs/workflow.json

# Optional placeholders if you want to wire the showcase to an external LLM later.
SCID_LLM__API_KEY=replace-me
SCID_LLM__BASE_URL=https://api.openai.com/v1
SCID_LLM__INTERVIEWER_MODEL=gpt-4o-mini
SCID_LLM__EXTRACTOR_MODEL=gpt-4o-mini
SCID_LLM__EVALUATOR_MODEL=gpt-4o-mini
SCID_LLM__TEMPERATURE=0.2
